# Copie este arquivo para .env e preencha com valores reais

# PostgreSQL Configurações
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_this_to_strong_password
POSTGRES_DB=postgres

# Configurações da Aplicação
DATABASE_URL=postgresql://admin:change_this_to_strong_password@localhost:5432/scheduling_lab
SECRET_KEY=change_this_to_random_secret_key

# Configurações de Porta
POSTGRES_PORT=5432
APP_PORT=8000